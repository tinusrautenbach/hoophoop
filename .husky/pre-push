#!/bin/sh
# Git pre-push hook to run CI checks before pushing to remote
# This ensures code quality is maintained before merging to main

echo "🔍 Running CI checks before push..."
echo ""

# Run the full CI check
npm run ci:check

# Check the exit code
if [ $? -ne 0 ]; then
    echo ""
    echo "❌ CI checks failed!"
    echo "Please fix the errors above before pushing."
    exit 1
fi

echo ""
echo "✅ All CI checks passed!"
echo ""

exit 0
