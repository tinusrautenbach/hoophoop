{
  "name": "hoophoop",
  "version": "0.2.0-alpha",
  "private": true,
  "scripts": {
    "dev": "nodemon server.ts",
    "dev:e2e": "PORT=3002 NEXT_PUBLIC_USE_MOCK_AUTH=true npm run dev",
    "build": "next build",
    "start": "tsx server.ts",
    "lint": "eslint",
    "test": "vitest --config tests/vitest.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:stress": "bash -c 'for i in {1..10}; do echo \"=== Run $i/10 ===\"; npx playwright test || exit 1; done'",
    "test:e2e:setup": "tsx scripts/validate-e2e-env.ts",
    "hasura:setup": "node scripts/migrate.mjs && node scripts/force-migrate-hasura.mjs",
    "typecheck": "tsc --noEmit",
    "ci:check": "npm run lint && npm run typecheck && npm audit --audit-level=moderate && npm run test -- --run --reporter=verbose",
    "install-hooks": "bash scripts/install-hooks.sh"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.37.3",
    "@clerk/shared": "^3.45.0",
    "@dnd-kit/core": "^6.3.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.33.0",
    "graphql": "^16.12.0",
    "graphql-ws": "^6.0.7",
    "lucide-react": "^0.563.0",
    "next": "^16.1.7",
    "nodemailer": "^8.0.1",
    "opencode-google-antigravity-auth": "^0.2.15",
    "postgres": "^3.4.8",
    "rate-limiter-flexible": "^9.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-qr-code": "^2.0.18",
    "tailwind-merge": "^3.4.0",
    "tsx": "^4.21.0",
    "winston": "^3.19.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@clerk/testing": "^1.14.3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.0",
    "eslint": "^10.0.1",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.0.0",
    "nodemon": "^3.1.11",
    "speckit": "^0.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
